generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id                Int       @id @default(autoincrement()) @map("admin_id")
  email             String    @unique
  password          String
  deletedUsers      User[]    @relation("DeletedUser") // Pluralized
  cancelledBookings Booking[] @relation("CancelledBookings")
}

model User {
  id               Int       @id @default(autoincrement()) @map("user_id")
  email            String    @unique
  password         String
  fullName         String    @map("full_name")
  bookings         Booking[]
  reviews          Review[]
  deletedByAdminId Int?      @map("deleted_by_admin_id")
  deletedByAdmin   Admin?    @relation("DeletedUser", fields: [deletedByAdminId], references: [id])
}

model Booking {
  id                 Int       @id @default(autoincrement()) @map("booking_id")
  date               DateTime?
  totalPrice         Float?    @map("total_price")
  
  // Removed redundant destination and flightNumber fields

  userId             Int       @map("user_id") // Added map for consistency
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  flightId           Int       @map("flight_id") // Added map for consistency
  flight             Flight    @relation(fields: [flightId], references: [id])

  cancelledByAdminId Int?      @map("cancelled_by_admin_id")
  cancelledByAdmin   Admin?    @relation("CancelledBookings", fields: [cancelledByAdminId], references: [id])

  review             Review?
}

model Review {
  id        Int      @id @default(autoincrement()) @map("review_id")
  score     Float
  comment   String
  createdAt DateTime @default(now()) @map("created_at")

  userId    Int      @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookingId Int      @unique @map("booking_id")
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Flight {
  id            Int         @id @default(autoincrement()) @map("flight_id")
  flightNumber  String      @map("flight_no")
  price         Float
  departure     String

  destinationId Int         @map("destination_id")
  destination   Destination @relation(fields: [destinationId], references: [id])

  bookings      Booking[]
}

model Destination {
  id        Int        @id @default(autoincrement()) @map("dest_id")
  name      String
  country   String
  imageUrl  String?    @map("image_url")

  flights   Flight[]
  topPlaces TopPlace[]
}

model TopPlace {
  id            Int         @id @default(autoincrement())
  photoNumber   Int         @map("photo_number")
  imageUrl      String      @map("image_url")
  caption       String

  destinationId Int         @map("destination_id") // Added map for consistency
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}